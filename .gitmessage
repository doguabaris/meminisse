# If you are unsure about what to use for component:
#  - "cli" for plugins/meminisse/scripts/meminisse.js changes
#  - "install" for personal plugin installer and marketplace changes
#  - "skill" for Codex skill instruction changes
#  - "docs" for README, contributing, publishing, and policy changes
#  - "config" for linting, formatting, package, and Docker changes
